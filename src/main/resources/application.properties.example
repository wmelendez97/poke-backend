# The properties should be in the gitignore but for practical purposes it will not be ignored.
spring.mvc.servlet.path=/api
spring.application.name=poke-backend
spring.boot.version.validation.enabled=false
spring.threads.virtual.enabled=true
spring.main.banner-mode=log

# ==============================
# External API
# ==============================
external.api.base-url=https://dummyjson.com/
external.api.pokeapi.base-url=https://pokeapi.co/api/v2
external.api.active=pokeapi

# ==============================
# Datasource postgresql
# ==============================
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.url=jdbc:postgresql://db:5432/<database>
spring.datasource.username=<username>
spring.datasource.password=<password>
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration
spring.flyway.baseline-on-migrate=true
logging.level.org.flywaydb=ERROR

# ==============================
# JPA / Hibernate
# ==============================
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# ==============================
# Swagger
# ==============================
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.tagsSorter=alpha
springdoc.swagger-ui.operationsSorter=alpha
springdoc.api-docs.path=/v3/api-docs
springdoc.packages-to-scan=com.poke.api.controller

# ==============================
# JWT
# ==============================
jwt.secret=<KeyDefinitionForJWTVeryLongInOrderToProgressWithTheTechnicalTest2026>
jwt.expiration=3600000

# ==============================
# Log4j2
# ==============================
logging.config=classpath:log4j2.properties
logging.file.path=./logs
logging.file.name=poke

# ==============================
# Actuator
# ==============================
management.endpoint.logfile.enabled=true
management.endpoint.logfile.external-file=./logs/poke.log
management.endpoints.web.exposure.include=health,info,logfile
management.endpoints.enabled-by-default=false
logging.level.root=ERROR
